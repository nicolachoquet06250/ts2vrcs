---
import Layout from '../layouts/Layout.astro';

const github = "https://github.com/nicolachoquet06250/ts2vrcs";
---

<Layout>
	<div class="relative isolate overflow-hidden">
		<!-- Background glow -->
		<div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
			<div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
		</div>

		<div class="container mx-auto px-4 pt-20 pb-32 sm:pt-32 sm:pb-40">
			<div class="text-center">
				<h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl bg-gradient-to-b from-white to-white/50 bg-clip-text text-transparent">
					Transpilez vos fichiers TypeScript <br class="hidden sm:inline" /> en scripts C# pour UdonSharp.
				</h1>
				<p class="mt-6 text-lg leading-8 text-gray-300 max-w-2xl mx-auto">
					Un outil puissant pour convertir vos scripts TypeScript vers le format C# compatible avec VRChat et UdonSharp.
				</p>
				<div class="mt-10 flex items-center justify-center gap-x-6">
					<a href="/docs/intro" class="rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black shadow-sm hover:bg-gray-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-all">
						Commencer
					</a>
					<a href={github} class="text-sm font-semibold leading-6 text-white hover:text-gray-300 transition-colors">
						Voir sur GitHub <span aria-hidden="true">→</span>
					</a>
				</div>
			</div>

			<div class="mt-20 rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm sm:mt-24">
				<div class="rounded-lg bg-[#0d1117] p-8 overflow-x-auto flex items-center justify-between group">
					<pre class="text-sm sm:text-base text-gray-300 font-mono whitespace-nowrap" id="command-line"><code><span class="text-purple-400">ts2vrcs</span> <span class="text-green-400">./src</span> <span class="text-purple-400">--output</span> <span class="text-green-400">./dist-cs</span></code></pre>
					<button
						id="copy-button"
						class="p-2 text-gray-400 hover:text-white bg-white/5 hover:bg-white/10 rounded-lg transition-all opacity-0 group-hover:opacity-100 focus:opacity-100"
						title="Copier la commande"
					>
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 copy-icon">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
						</svg>
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 check-icon hidden">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
						</svg>
					</button>
				</div>
			</div>
		</div>

		<div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]" aria-hidden="true">
			<div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
		</div>
	</div>

	<div class="py-24 sm:py-32 bg-[#080808]/50 backdrop-blur-3xl relative z-10">
		<div class="container mx-auto px-4">
			<div class="mx-auto max-w-2xl lg:text-center">
				<h2 class="text-base font-semibold leading-7 text-orange-500">Rapide & Efficace</h2>
				<p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">La puissance de TypeScript pour UdonSharp</p>
			</div>
			<div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
				<dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3">
					<div class="flex flex-col">
						<dt class="flex items-center gap-x-3 text-base font-semibold leading-7 text-white">
							<div class="h-10 w-10 flex items-center justify-center rounded-lg bg-orange-500/10 text-orange-500">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
								</svg>
							</div>
							Performance native
						</dt>
						<dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-400">
							<p class="flex-auto">Conçu pour être extrêmement rapide lors de la conversion de vos fichiers TypeScript vers C#.</p>
						</dd>
					</div>
					<div class="flex flex-col">
						<dt class="flex items-center gap-x-3 text-base font-semibold leading-7 text-white">
							<div class="h-10 w-10 flex items-center justify-center rounded-lg bg-purple-500/10 text-purple-500">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							Type Safe
						</dt>
						<dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-400">
							<p class="flex-auto">Exploitez la puissance de TypeScript pour garantir que vos données sont toujours valides avant l'export.</p>
						</dd>
					</div>
					<div class="flex flex-col">
						<dt class="flex items-center gap-x-3 text-base font-semibold leading-7 text-white">
							<div class="h-10 w-10 flex items-center justify-center rounded-lg bg-blue-500/10 text-blue-500">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
									<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m2.786 14.197l-.513-1.411m-5.13-14.095l-.513-1.41M17.785 18.894l-.964-1.15m-9.642-11.49l-.964-1.15M19.795 16.499l-1.3-.75m-12.99-7.5l-1.3-.75" />
								</svg>
							</div>
							Facile à configurer
						</dt>
						<dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-400">
							<p class="flex-auto">Des options simples mais puissantes pour personnaliser votre compilation (SDK, UdonSharp versions).</p>
						</dd>
					</div>
				</dl>
			</div>
		</div>
	</div>
</Layout>

<script>
	const copyButton = document.getElementById('copy-button');
	const commandLine = document.getElementById('command-line');
	const copyIcon = copyButton?.querySelector('.copy-icon');
	const checkIcon = copyButton?.querySelector('.check-icon');

	copyButton?.addEventListener('click', async () => {
		if (commandLine) {
			const text = commandLine.textContent || '';
			await navigator.clipboard.writeText(text);

			// Show check icon
			copyIcon?.classList.add('hidden');
			checkIcon?.classList.remove('hidden');

			// Revert after 2 seconds
			setTimeout(() => {
				copyIcon?.classList.remove('hidden');
				checkIcon?.classList.add('hidden');
			}, 2000);
		}
	});
</script>
