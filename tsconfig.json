{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "#udon": ["./lib/udon.d.ts"]
    },
    "rootDirs": ["src", "lib"]
  },
  "include": ["src/**/*.ts", "lib/**/*.d.ts"]
}
